{
    "name": "fleet/ast-matcher",
    "description": "PHP AST pattern matching library",
    "require": {
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "zhamao/logger": "^1.1",
        "webmozart/assert": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "Fleet\\AstMatcher\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "2.0.0",
    "config": {
        "platform": {
            "php": "8.1.34"
        }
    }
}
